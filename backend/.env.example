# Backend Aura Clinic — copie para .env e ajuste os valores. NÃO commite o .env.
NODE_ENV=development
PORT=4000

# Banco de dados Postgres (obrigatório)
DATABASE_URL=postgres://postgres:SUA_SENHA@localhost:5432/aura_clinic
DATABASE_SSL=false

# Segredo dos tokens (obrigatório em produção). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=troque-por-um-valor-forte

# Origem permitida do frontend (CORS)
CORS_ORIGIN=http://localhost:5173

# Libera o endpoint destrutivo POST /api/admin/reset-demo-data em produção.
# Por padrão o reset fica BLOQUEADO quando NODE_ENV=production (retorna 403).
# Defina como "true" apenas quando realmente quiser permitir o reset em produção.
# ALLOW_DEMO_RESET=true

# ---------- Multi-tenant (SaaS) ----------
# Cada clínica (tenant) vive num schema Postgres próprio ("tenant_<id>").
# O tenant da requisição é resolvido por: token → header X-Tenant → DEFAULT_TENANT.

# Clínica padrão quando a requisição não traz X-Tenant nem token.
# Útil em dev local (ex.: aura). Em PRODUÇÃO defina apenas se fizer sentido
# (ex.: instância dedicada a uma clínica); caso contrário, deixe indefinida
# para exigir o header X-Tenant explicitamente.
# DEFAULT_TENANT=aura

# Superadmin inicial do painel de plataforma. Semeado no primeiro boot SOMENTE
# se a tabela platform.platform_users estiver vazia.
# Em PRODUÇÃO estas envs são OBRIGATÓRIAS para semear (sem elas o boot apenas
# avisa e NÃO cria credenciais padrão). Use e-mail real e senha forte.
# PLATFORM_ADMIN_EMAIL=superadmin@suaempresa.com
# PLATFORM_ADMIN_PASSWORD=troque-por-uma-senha-forte

# Cadastro público de clínicas em POST /api/signup.
# "false" desabilita (o painel de plataforma continua podendo criar clínicas).
# Qualquer outro valor (ou ausente) mantém o signup público habilitado.
# Defina conforme a estratégia de vendas: aberto (true) ou só via plataforma (false).
# ALLOW_PUBLIC_SIGNUP=true
