# Variáveis de ambiente para Aura Clinic Piercing
# Copie este arquivo para .env.local e defina seus valores

# Senha da Central Administrativa
# Altere isso em produção! Use uma senha forte.
VITE_ADMIN_PASSWORD=aura123

# Ambiente
NODE_ENV=development

# Porta do servidor (opcional, padrão: 4000)
PORT=4000

# Auth Secret para tokens JWT (opcional, padrão: aura-clinic-dev-secret)
AUTH_SECRET=aura-clinic-dev-secret

# Para produção, defina um valor seguro e único
# Exemplo: AUTH_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
